# ==================== 构建产物 ====================
*.iml
.gradle/
local.properties
.idea/
.DS_Store
.build/
/caches
**/build/**

# Room Database Schemas (可选保留)
schemas/

# ==================== 应用 libs 目录（保留 SDK JAR） ====================
# 不忽略 app/libs 中的 JAR 文件（地图 SDK 等第三方库）
!app/libs/*.jar

# ==================== 签名密钥库 ====================
*.jks
*.keystore
keystore.properties
keystore.jks
keystore.base64

# ==================== 敏感配置 ====================
# API Keys（应使用 GitHub Secrets）
google-api-key.txt
amap_api_key.txt
baidu_api_key.txt
supabase_config.txt

# ==================== 日志文件 ====================
*.log
logs/

# ==================== 临时文件 ====================
*.tmp
*.bak
*.swp
*~

# ==================== 发布相关 ====================
release-notes.txt
upload-archived-artifacts/
